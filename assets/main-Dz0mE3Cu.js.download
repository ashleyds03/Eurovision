"use strict";
const workerSelf = self;
let eventSource = null;
let currentConfig = null;
let retryCount = 0;
let retryTimeoutId = null;
let connectionInProgress = false;
const maxRetries = 5;
const connectedPorts = new Map();
let lastSleepMs = null;
let currentRcs = null;
let ttlTimeoutId = null;
let leaderPortId = null;
let ddrTimeoutId = null;
const fn = {
    startConnection: null,
    handleMessage: null,
};
function broadcast(message) {
    connectedPorts.forEach((portInfo, portId) => {
        try {
            portInfo.port.postMessage(message);
        }
        catch (_a) {
            connectedPorts.delete(portId);
        }
    });
}
function randomInclusive(min, max) {
    return Math.floor(Math.random() * (max - min + 1)) + min;
}
function electLeader() {
    if (leaderPortId && connectedPorts.has(leaderPortId)) {
        return;
    }
    const firstPortId = connectedPorts.keys().next().value;
    leaderPortId = firstPortId || null;
    if (leaderPortId) {
        console.log("[Braze Real-Time] Elected leader port:", leaderPortId);
    }
}
function promoteToLeader(portId) {
    if (connectedPorts.has(portId) && leaderPortId !== portId) {
        leaderPortId = portId;
        console.log("[Braze Real-Time] Promoted to leader (tab became active):", portId);
    }
}
function sendToLeader(message) {
    electLeader();
    if (!leaderPortId) {
        console.warn("[Braze Real-Time] No leader to send message to");
        return;
    }
    const leader = connectedPorts.get(leaderPortId);
    if (leader) {
        try {
            leader.port.postMessage(message);
        }
        catch (_a) {
            connectedPorts.delete(leaderPortId);
            leaderPortId = null;
            sendToLeader(message);
        }
    }
}
function closeConnection() {
    connectionInProgress = false;
    if (retryTimeoutId !== null) {
        clearTimeout(retryTimeoutId);
        retryTimeoutId = null;
    }
    if (ttlTimeoutId !== null) {
        clearTimeout(ttlTimeoutId);
        ttlTimeoutId = null;
    }
    if (ddrTimeoutId !== null) {
        clearTimeout(ddrTimeoutId);
        ddrTimeoutId = null;
    }
    if (eventSource) {
        eventSource.close();
        eventSource = null;
        broadcast({ type: "disconnected" });
    }
}
function retryWithBackoff() {
    if (!currentConfig) {
        return;
    }
    retryCount++;
    const { minSleepMs, maxSleepMs, scaleFactor } = currentConfig.backoff;
    let previousSleepMs = lastSleepMs;
    if (previousSleepMs == null || previousSleepMs < minSleepMs) {
        previousSleepMs = minSleepMs;
    }
    const backoffMs = Math.min(maxSleepMs, randomInclusive(minSleepMs, previousSleepMs * scaleFactor));
    lastSleepMs = backoffMs;
    console.log("[Braze Real-Time] Retrying in " + backoffMs + "ms (attempt " + retryCount + "/" + maxRetries + ")");
    retryTimeoutId = setTimeout(function () {
        retryTimeoutId = null;
        fn.startConnection();
    }, backoffMs);
}
function startConnection(oldEventSourceToClose) {
    if (!currentConfig) {
        return;
    }
    if (eventSource && !oldEventSourceToClose) {
        console.warn("[Braze Real-Time] Connection already exists");
        return;
    }
    if (connectionInProgress && !oldEventSourceToClose) {
        console.warn("[Braze Real-Time] Connection attempt already in progress");
        return;
    }
    connectionInProgress = true;
    const { dustHost, mite, auth } = currentConfig;
    const dustHostWithScheme = /^https?:\\/\\//i.test(dustHost) ? dustHost : "https://" + dustHost;
    let queryString = "mite=" + encodeURIComponent(mite) + "&attempts=" + retryCount;
    if (auth) {
        queryString += "&auth=" + encodeURIComponent(auth);
    }
    if (currentRcs) {
        queryString += "&rcs=" + encodeURIComponent(currentRcs);
    }
    const subscribeUrl = dustHostWithScheme + "/sse?" + queryString;
    try {
        const newEventSource = new EventSource(subscribeUrl);
        newEventSource.onopen = function () {
            if (oldEventSourceToClose) {
                console.log("[Braze Real-Time] Gapless reconnection: new connection established, closing old connection");
                oldEventSourceToClose.close();
            }
            else {
                console.log("[Braze Real-Time] Connection established");
            }
            eventSource = newEventSource;
            connectionInProgress = false;
            retryCount = 0;
            lastSleepMs = null;
            broadcast({ type: "connected" });
        };
        newEventSource.addEventListener("msg", function (event) {
            fn.handleMessage(event.data);
        });
        newEventSource.onerror = function () {
            const readyState = newEventSource ? newEventSource.readyState : -1;
            if (readyState === 0) {
                console.log("[Braze Real-Time] Failed to connect");
            }
            else {
                console.log("[Braze Real-Time] Connection lost");
            }
            if (oldEventSourceToClose && eventSource !== newEventSource) {
                console.log("[Braze Real-Time] Gapless reconnection failed, keeping old connection");
                newEventSource.close();
                connectionInProgress = false;
                if (retryCount < maxRetries) {
                    retryWithBackoff();
                }
                return;
            }
            closeConnection();
            if (retryCount < maxRetries) {
                retryWithBackoff();
            }
            else {
                console.error("[Braze Real-Time] Max retries reached");
                broadcast({ type: "error", error: "Max retry attempts reached" });
            }
        };
    }
    catch (error) {
        connectionInProgress = false;
        console.error("[Braze Real-Time] Failed to create EventSource:", error);
        broadcast({ type: "error", error: String(error) });
    }
}
function handleTtlMessage(tMs, rcs) {
    if (typeof tMs !== "number") {
        return;
    }
    if (typeof rcs === "string") {
        currentRcs = rcs;
    }
    console.log("[Braze Real-Time] TTL set to " + tMs + "ms, will perform gapless reconnection when expired");
    if (ttlTimeoutId !== null) {
        clearTimeout(ttlTimeoutId);
    }
    ttlTimeoutId = setTimeout(function () {
        ttlTimeoutId = null;
        console.log("[Braze Real-Time] TTL expired, performing gapless reconnection");
        startConnection(eventSource || undefined);
    }, tMs);
}
function handleDdrMessage(rMs, reason) {
    if (typeof rMs !== "number") {
        return;
    }
    const jitter = Math.random() * rMs * 0.3;
    const waitMs = Math.round(rMs + jitter);
    const reasonStr = reason ? " (" + reason + ")" : "";
    console.log("[Braze Real-Time] Admin requested disconnect" + reasonStr + ", reconnecting in " + waitMs + "ms");
    if (ddrTimeoutId !== null) {
        clearTimeout(ddrTimeoutId);
    }
    closeConnection();
    ddrTimeoutId = setTimeout(function () {
        ddrTimeoutId = null;
        fn.startConnection();
    }, waitMs);
}
function handleMessage(data) {
    try {
        const message = JSON.parse(data);
        if (!message.type) {
            console.warn("[Braze Real-Time] Message without type:", message);
            return;
        }
        if (message.type === "ttl" && message.body) {
            handleTtlMessage(message.body.t_ms, message.body.rcs);
            return;
        }
        if (message.type === "ddr" && message.body) {
            handleDdrMessage(message.body.r_ms, message.body.e);
            return;
        }
        console.log("[Braze Real-Time] Routing '" + message.type + "' message to leader");
        sendToLeader({ type: "message", data: message });
    }
    catch (error) {
        console.warn("[Braze Real-Time] Failed to parse message:", error);
    }
}
fn.startConnection = startConnection;
fn.handleMessage = handleMessage;
function handlePortMessage(port, portId, message) {
    switch (message.type) {
        case "connect":
            if (currentConfig &&
                (currentConfig.mite !== message.config.mite || currentConfig.dustHost !== message.config.dustHost)) {
                console.log("[Braze Real-Time] Config changed, reconnecting");
                closeConnection();
                retryCount = 0;
                lastSleepMs = null;
                currentRcs = null;
            }
            currentConfig = message.config;
            electLeader();
            if (!eventSource && !connectionInProgress) {
                startConnection();
            }
            else if (eventSource) {
                port.postMessage({ type: "connected" });
            }
            break;
        case "disconnect":
            connectedPorts.delete(portId);
            if (portId === leaderPortId) {
                leaderPortId = null;
                electLeader();
            }
            if (connectedPorts.size === 0) {
                console.log("[Braze Real-Time] No more ports, closing connection");
                closeConnection();
                currentConfig = null;
                currentRcs = null;
                leaderPortId = null;
            }
            break;
        case "tab_active":
            promoteToLeader(portId);
            break;
        case "ping":
            port.postMessage({ type: "pong" });
            break;
        default:
            console.warn("[Braze Real-Time] Unknown message type:", message.type);
    }
}
workerSelf.onconnect = function (event) {
    const port = event.ports[0];
    const portId = "port-" + Date.now() + "-" + Math.random().toString(36).substr(2, 9);
    connectedPorts.set(portId, { port: port });
    port.onmessage = function (messageEvent) {
        try {
            handlePortMessage(port, portId, messageEvent.data);
        }
        catch (error) {
            console.error("[Braze Real-Time] Error handling message:", error);
        }
    };
    port.onmessageerror = function () {
        console.warn("[Braze Real-Time] Message error from port:", portId);
        connectedPorts.delete(portId);
    };
